
      "cell_type": "code",
      "source": [
        "import random\n",
        "\n",
        "# 問題（日本語 : カタルーニャ語）\n",
        "words = {\n",
        "    \"懐中電灯\": \"llanterna\",\n",
        "    \"マッチ箱\": \"capsa de llumins\",\n",
        "    \"食堂\": \"cantimplora\",\n",
        "    \"多目的ナイフ\": \"navalla multiús\",\n",
        "    \"コンパス\": \"brúixola\",\n",
        "    \"薬箱\":\"farmaciola\",\n",
        "    \"虫よけスプレー\":\"repel·lent de mosquitos\",\n",
        "    \"コーチ\":\"autocar\",\n",
        "    \"カード\":\"corda\",\n",
        "    \"ハサミ\":\"tisores\",\n",
        "    \"アウトドアウェア\":\"anorac\"\n",
        "}\n",
        "\n",
        "# ランダムで問題を出す\n",
        "japanese = random.choice(list(words.keys()))\n",
        "answer = words[japanese]\n",
        "\n",
        "print(\"次の単語をカタルーニャ語で答えてください\")\n",
        "print(\"👉\", japanese)\n",
        "\n",
        "user = input(\"答え：\")\n",
        "\n",
        "if user.strip().lower() == answer.lower():\n",
        "    print(\"正解！🎉\")\n",
        "else:\n",
        "    print(\"不正解\")\n",
        "    print(\"正しくは：\", answer)"
      ],
